# --- Dependencies ---
node_modules/

# --- direnv ---
.envrc

# --- Build outputs ---
.next/
out/
dist/
build/
coverage/
.open-next/
.wrangler/
.dev.vars


# --- Paper PDFs (large files) ---
paper/
*.pdf
posts/papers/*/paper/

# --- Post images (served from Cloudflare R2 CDN) ---
# OG images (public/posts/<slug>/og.png) are kept for social crawlers
public/posts/*/cover*.webp
public/posts/*/cover-thumb*.webp
public/posts/*/fig-*
public/posts/*/tab-*

# --- Publish caches ---
.substack-published.json
.social-published.json

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# --- Environment files (secrets) ---
.env
.env.local
.env*.local
!.env.example

# --- Vercel / local deployment state ---
.vercel/

# --- Claude / MCP local-only configs (if created locally) ---
.mcp.json
.mcp.local.json
.claude/settings.local.json
.claude/scheduled_tasks.lock

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# --- Temp / caches ---
.tmp/
temp/
.cache/
tsconfig.tsbuildinfo

# --- Python (if utility scripts are added later) ---
__pycache__/
*.pyc
.venv/

.vercel
supabase/.temp/

# Obsidian integration (private paths)
posts/global-index.json
_workspace/
scripts/upload-private-content.mjs
posts/index-private.json

# Post source images (served from R2 CDN, kept locally for dev only)
posts/papers/*/fig-*
posts/papers/*/tab-*
posts/papers/*/cover.webp
posts/papers/*/cover-thumb.webp
posts/essays/*/cover.webp
posts/essays/*/cover-thumb.webp
posts/essays/*/cover.png
posts/memos/*/cover.webp

# Local-only throwaway scripts (one-off migrations, exploratory helpers).
# Keep migration scripts under scripts/archive/<date>-<topic>/ for local audit;
# the archive itself stays gitignored — git history of the original commit is
# the source of truth, the directory is just a parking lot.
scripts/_*
scripts/archive/

# Generated by scripts/generate-post-bodies.mjs (build step). Holds inline ?raw
# imports of every public MDX body so getPost can serve Workers without fs.
src/data/post-bodies.ts
