# ============================================================
# .env.example
# Copy this file to .env.local and fill in real values locally.
# NEVER commit .env.local or any real secrets.
# ============================================================

# ------------------------------------------------------------
# Site / App
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME=Terry Um

# ------------------------------------------------------------
# AI APIs (server-side only)
# Do NOT prefix with NEXT_PUBLIC_
# ------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ------------------------------------------------------------
# Optional image/asset generation providers (server-side)
# Fill only if used
# ------------------------------------------------------------
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# ------------------------------------------------------------
# Admin (server-side only)
# ------------------------------------------------------------
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ------------------------------------------------------------
# Group Access Control (server-side only)
# Each group gets its own password: CO_{GROUP}_PASSWORD
# Group slug is uppercased with hyphens replaced by underscores
# Example: group "snu" → CO_SNU_PASSWORD, "kaist-lab" → CO_KAIST_LAB_PASSWORD
# ------------------------------------------------------------
CO_SNU_PASSWORD=
CO_KAIST_PASSWORD=

# ------------------------------------------------------------
# GA4 Analytics Data API (admin stats dashboard, server-side)
# GA4_SERVICE_ACCOUNT_JSON should be base64-encoded JSON key file
# ------------------------------------------------------------
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# ------------------------------------------------------------
# Analytics (choose later; keep empty until tool is selected)
# Public IDs are okay to expose only if the provider expects it.
# ------------------------------------------------------------
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# GA4 클라이언트 측 추적 ID (G-XXXXXXXXXX 형식)
# analytics.google.com → 관리 → 데이터 스트림 → 측정 ID
# 미설정 시 gtag.js 코드가 삽입되지 않음 (데이터 수집 없음)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ------------------------------------------------------------
# Search / indexing integrations (optional)
# ------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ------------------------------------------------------------
# CMS / GitHub automation (optional, server-side)
# Only add if automation requires GitHub API access.
# ------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ------------------------------------------------------------
# Cloudflare (optional, only if automation touches DNS/Cache APIs)
# Keep server-side only
# ------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ------------------------------------------------------------
# Substack 연동 (v1: 구독 위젯 + GitHub Actions 자동 포스팅)
# NEXT_PUBLIC_* → 브라우저에 노출됨 (Substack URL은 공개 정보라 OK)
# SUBSTACK_EMAIL / SUBSTACK_PASSWORD → GitHub Secrets에만 등록 (서버 전용)
# ------------------------------------------------------------
NEXT_PUBLIC_SUBSTACK_EN_URL=https://your-publication-en.substack.com
NEXT_PUBLIC_SUBSTACK_KO_URL=https://your-publication-ko.substack.com
# Chrome -> F12 -> Application -> Cookies -> substack.com -> substack.sid 값
SUBSTACK_COOKIE=

# ------------------------------------------------------------
# Social Media 자동 공유 (v2 — scripts/publish-social.py)
# Facebook Long-lived Page Token은 만료 없음
# Threads / LinkedIn Token은 60일 만료 → TOKEN_CREATED 날짜 기록 필수
# X OAuth 1.0a Token은 만료 없음 (앱 권한 유지 시)
# ------------------------------------------------------------
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_BASE_URL=https://www.terryum.ai  # OG 크롤러가 fetch하는 canonical URL

THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_TOKEN_CREATED=          # 발급일 YYYY-MM-DD (만료 경고용)

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=            # urn:li:person:xxxxx
LINKEDIN_TOKEN_CREATED=         # 발급일 YYYY-MM-DD

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

BLUESKY_IDENTIFIER=             # handle (e.g. user.bsky.social)
BLUESKY_APP_PASSWORD=           # App Password (Settings → App Passwords, 만료 없음)

# ------------------------------------------------------------
# Newsletter / Email (v2+ only; leave blank in v1)
# ------------------------------------------------------------
EMAIL_PROVIDER=
RESEND_API_KEY=
MAILERLITE_API_KEY=
CONVERTKIT_API_SECRET=
BUTTONDOWN_API_KEY=

# ------------------------------------------------------------
# Supabase (Paper Graph DB)
# NEXT_PUBLIC_* → 브라우저에서 사용 (RLS로 보호)
# SUPABASE_SERVICE_ROLE_KEY → 서버/스크립트 전용 (절대 브라우저 노출 금지)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# MCP / local tooling
# Prefer user/local scope config and local env vars.
# ------------------------------------------------------------
MCP_SERVER_URL=
MCP_AUTH_TOKEN=
