# ============================================================
# .env.example
# Copy this file to .env.local and fill in real values locally.
# NEVER commit .env.local or any real secrets.
# ============================================================

# ------------------------------------------------------------
# Site / App
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME=Terry Um

# ------------------------------------------------------------
# AI APIs (server-side only)
# Do NOT prefix with NEXT_PUBLIC_
# ------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ------------------------------------------------------------
# Optional image/asset generation providers (server-side)
# Fill only if used
# ------------------------------------------------------------
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# ------------------------------------------------------------
# Admin (server-side only)
# ------------------------------------------------------------
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ------------------------------------------------------------
# GA4 Analytics Data API (admin stats dashboard, server-side)
# GA4_SERVICE_ACCOUNT_JSON should be base64-encoded JSON key file
# ------------------------------------------------------------
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# ------------------------------------------------------------
# Analytics (choose later; keep empty until tool is selected)
# Public IDs are okay to expose only if the provider expects it.
# ------------------------------------------------------------
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
VERCEL_WEB_ANALYTICS_ENABLED=

# ------------------------------------------------------------
# Search / indexing integrations (optional)
# ------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ------------------------------------------------------------
# CMS / GitHub automation (optional, server-side)
# Only add if automation requires GitHub API access.
# ------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# ------------------------------------------------------------
# Cloudflare (optional, only if automation touches DNS/Cache APIs)
# Keep server-side only
# ------------------------------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ------------------------------------------------------------
# Vercel (optional for local scripts / CLI automation)
# Usually set in Vercel project settings instead of local env.
# ------------------------------------------------------------
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
VERCEL_TOKEN=

# ------------------------------------------------------------
# Substack 연동 (v1: 구독 위젯 + GitHub Actions 자동 포스팅)
# NEXT_PUBLIC_* → 브라우저에 노출됨 (Substack URL은 공개 정보라 OK)
# SUBSTACK_EMAIL / SUBSTACK_PASSWORD → GitHub Secrets에만 등록 (서버 전용)
# ------------------------------------------------------------
NEXT_PUBLIC_SUBSTACK_EN_URL=https://your-publication-en.substack.com
NEXT_PUBLIC_SUBSTACK_KO_URL=https://your-publication-ko.substack.com
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=

# ------------------------------------------------------------
# Newsletter / Email (v2+ only; leave blank in v1)
# ------------------------------------------------------------
EMAIL_PROVIDER=
RESEND_API_KEY=
MAILERLITE_API_KEY=
CONVERTKIT_API_SECRET=
BUTTONDOWN_API_KEY=

# ------------------------------------------------------------
# MCP / local tooling
# Prefer user/local scope config and local env vars.
# ------------------------------------------------------------
MCP_SERVER_URL=
MCP_AUTH_TOKEN=
