{
  "name": "terryum-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/clean-next.mjs && next dev -p 3040",
    "build": "node scripts/clean-next.mjs && next build",
    "build:full": "node scripts/clean-next.mjs && node scripts/copy-post-images.mjs && node scripts/generate-thumbnails.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "generate-logos": "node scripts/generate-logos.mjs",
    "generate-og": "node scripts/generate-og-image.mjs",
    "sync-papers": "node scripts/sync-papers.mjs",
    "test-graph": "node scripts/test-graph.mjs",
    "sync-obsidian": "node scripts/sync-obsidian.mjs",
    "sync-obsidian:init": "node scripts/sync-obsidian.mjs --init",
    "build:cf": "node scripts/clean-next.mjs && opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@google-analytics/data": "^5.2.1",
    "@supabase/supabase-js": "^2.99.2",
    "@xyflow/react": "^12.10.1",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "katex": "^0.16.33",
    "next": "^15.2.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "recharts": "^3.8.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.11.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "playwright": "^1.50.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "4.42.2"
  }
}
