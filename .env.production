# NEXT_PUBLIC_* values committed for Cloudflare Pages build.
# Next.js reads .env.production during `next build` with NODE_ENV=production
# and inlines NEXT_PUBLIC_* into the client JS bundle at compile time.
# wrangler.jsonc `vars` alone is not enough because those are runtime-only.
#
# Safe to commit: these are designed to be public (RLS-protected anon keys,
# public GA ID, public CDN URL, etc). Real secrets (service role key, admin
# passwords, etc.) remain in Cloudflare Dashboard as encrypted Secrets.

NEXT_PUBLIC_SITE_URL=https://terry.artlab.ai
